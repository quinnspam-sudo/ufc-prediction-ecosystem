# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Scratch output from `main.py --json-out` (top-level only).
# NOTE: reports/*.json and data_store/state.json ARE tracked on purpose —
# they're the persistent state the auto-updater commits each cycle.
/report.json
/*.report.json

# Secrets — NEVER commit these. API keys live only in GitHub Actions secrets
# (repo Settings → Secrets) and local env vars, never in the repo.
.env
.env.*
*.local
secrets.json
credentials.json
*.pem
*.key
*_token
*_secret
.odds_api_key

